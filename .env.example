# Sanity (create project at sanity.io/manage, then set these)
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# For Next.js front-end (fetching content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# For seed script and Presentation/draft mode (create token with Editor permissions at sanity.io/manage)
SANITY_API_TOKEN=

# Optional: Preview URL for Presentation tool and Configure with Claude API (default: http://localhost:3000)
# Studio calls Next app at this URL. Both must run locally (Studio :3333, Next :3000).
# SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# SANITY_STUDIO_APP_URL=http://localhost:3000

# Optional: Studio URL for click-to-edit overlays (default: http://localhost:3333)
# SANITY_STUDIO_URL=http://localhost:3333

# For JioKarna (AI-powered page builder)
ANTHROPIC_API_KEY=

{
  "name": "page-architect",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "sanity dev",
    "predev:app": "npm run generate:tokens",
    "dev:app": "next dev",
    "dev:api": "next dev -p 3001",
    "generate:tokens": "node scripts/generate-ds-tokens-css.mjs",
    "seed:sanity": "node --env-file=.env scripts/seed-sanity.mjs",
    "clear:images": "node --env-file=.env scripts/clear-images-and-assets.mjs",
    "seed:pixel-10-pro": "node --env-file=.env scripts/seed-pixel-10-pro.mjs",
    "seed:jiogames": "node --env-file=.env scripts/seed-jiogames.mjs",
    "generate:icons": "node -e \"const icons=require('@marcelinodzn/ds-react/icons');const fs=require('fs');const names=icons.getAvailableIcons();fs.mkdirSync('src/lib',{recursive:true});fs.writeFileSync('src/lib/ds-icon-names.json',JSON.stringify(names));console.log('Wrote',names.length,'icon names');\"",
    "postinstall": "patch-package",
    "prebuild": "npm run generate:tokens",
    "build": "next build",
    "start": "next start",
    "build:studio": "sanity build",
    "deploy:studio": "sanity deploy",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic --project-token=chpt_349d5808045d456"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@base-ui/react": "^1.2.0",
    "@marcelinodzn/ds-react": "^1.0.6",
    "@marcelinodzn/ds-tokens": "^1.0.1",
    "@sanity/client": "^7.16.0",
    "@sanity/icons": "^3.4.0",
    "json5": "^2.2.3",
    "next": "^16.1.6",
    "next-sanity": "^12.1.0",
    "react": "^19.2.4",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "^19.2.4",
    "sanity": "^5.12.0",
    "styled-components": "^6.1.0",
    "use-debounce": "^10.1.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/nextjs-vite": "^10.2.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "chromatic": "^15.2.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "storybook": "^10.2.15",
    "typescript": "^5.6.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
